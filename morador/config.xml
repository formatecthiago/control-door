<?xml version='1.0' encoding='utf-8'?>
<widget id="com.formatecthiago.controldoor.morador" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>VirtyMorador</name>
    <description>Aplicativo do Morador - Control Door</description>
    <author email="suporte@control-door.com" href="https://github.com/formatecthiago/control-door">Thiago</author>
    
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <preference name="ScrollEnabled" value="false" />
    <preference name="BackupWebStorage" value="none" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="3000" />

    <platform name="android">
        <preference name="AndroidGradlePluginVersion" value="8.1.1" />
        <preference name="GradleVersion" value="8.1.1" />
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="33" />
        <allow-intent href="market:*" />
        
        <icon src="icon-192.png" />
        <icon density="ldpi" src="icon-192.png" />
        <icon density="mdpi" src="icon-192.png" />
        <icon density="hdpi" src="icon-192.png" />
        <icon density="xhdpi" src="icon-512.png" />
        <icon density="xxhdpi" src="icon-512.png" />
        <icon density="xxxhdpi" src="icon-512.png" />
    </platform>
</widget>
